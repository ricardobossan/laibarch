#!/bin/sh

# Steam launcher using a dedicated Xwayland instance spanning both monitors.
#
# Spawns Xwayland on :1 with a single 5120x1440 virtual output so games see
# it as one display. Connects to the running dwl Wayland session. Kills :1
# after Steam exits so nothing leaks into the regular session.
#
# For single-monitor or Wayland-native games, use 'steam' instead.

COMBINED=$(wlr-randr 2>/dev/null | awk '
  /current/ { match($0, /([0-9]+)x([0-9]+)/, m); w+=m[1]; if (m[2]>h) h=m[2] }
  END { print w "x" h }
')
GEOMETRY=${COMBINED:-5120x1440}

Xwayland :1 -geometry "$GEOMETRY" &
XWAYLAND_PID=$!
sleep 1

DISPLAY=:1 flatpak run com.valvesoftware.Steam "$@"

kill $XWAYLAND_PID 2>/dev/null
